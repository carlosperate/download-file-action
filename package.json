{
  "name": "download-file-action",
  "version": "2.0.3",
  "description": "GitHub Action to download a file from the internet into the workspace to use in your workflow.",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "package": "npm run build && ncc build ./build/src -o ./dist",
    "lint": "eslint src/**/*.ts",
    "test": "npm run package && NODE_OPTIONS=--experimental-vm-modules jest",
    "all": "npm run lint && npm test"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/carlosperate/download-file-action.git"
  },
  "keywords": [
    "GitHub",
    "github",
    "Action",
    "action",
    "Actions",
    "actions",
    "download",
    "file"
  ],
  "author": "Carlos Pereira Atencio",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/carlosperate/download-file-action/issues"
  },
  "homepage": "https://github.com/carlosperate/download-file-action#readme",
  "dependencies": {
    "@actions/core": "^1.10.0",
    "content-disposition": "^0.5.4",
    "ext-name": "^5.0.0",
    "file-type": "^21.3.2",
    "filenamify": "^4.3.0",
    "get-stream": "^6.0.1",
    "got": "^13.0.0",
    "make-dir": "^3.1.0",
    "md5-file": "^5.0.0",
    "p-event": "^4.2.0"
  },
  "devDependencies": {
    "@types/content-disposition": "^0.5.9",
    "@types/node": "^24.12.2",
    "@typescript-eslint/eslint-plugin": "^8.58.1",
    "@typescript-eslint/parser": "^8.58.1",
    "@vercel/ncc": "^0.38.4",
    "eslint": "^8.57.1",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-plugin-github": "^5.1.8",
    "eslint-plugin-import": "^2.32.0",
    "jest": "^30.3.0",
    "ts-jest": "^29.4.9",
    "typescript": "^6.0.2"
  }
}
